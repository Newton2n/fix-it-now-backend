model TechnicianCategory {
    id           String @id @default(uuid())
    technicianId String
    categoryId   String

    technicianProfile TechnicianProfile @relation(fields: [technicianId], references: [id])
    category          Category          @relation(fields: [categoryId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([technicianId])
    @@index([categoryId])
    @@map("technicianCategorys")
}
